# ===== 数据库配置 =====
DB_HOST=rm-xxxxxxxxxxxx.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=stock_analysis

# ===== 股票池（逗号分隔）=====
STOCK_CODES=600519,000858,000001,300750,601318

# ===== 数据拉取配置 =====
# 历史数据天数
HISTORY_DAYS=365
# 分钟线周期: 1 / 5 / 15 / 30 / 60
MINUTE_PERIOD=5

# ===== 定时任务（stock_data_job）=====
# 日线拉取（工作日 16:30）
JOB_DAILY_CRON=30 16 * * 1-5
# 分钟线拉取（工作日 15:30，收盘后拉当天全量）
JOB_MINUTE_CRON=30 15 * * 1-5
# 日志文件
JOB_LOG_FILE=stock_data_job.log

# ===== Web API =====
API_HOST=0.0.0.0
API_PORT=8000

# ===== 股池（stock_pool）=====
# 股池筛选定时（默认每月1号09:07）
POOL_CRON=7 9 1 * *
# 股池名称（筛选器版本，预留多套扩展）
POOL_NAME=default
# 筛选阈值：总市值(亿) / 流通市值近似(亿) / 上市天数(252交易日≈365)
POOL_MIN_TOTAL_MV=30
POOL_MIN_CIRC_MV=15
POOL_MIN_LISTING_DAYS=365

# ===== 信号系统（signal）=====
# 盘后扫描定时（工作日 17:00，在日线 16:30 / 分钟线 15:30 之后）
SIGNAL_CRON=0 17 * * 1-5
# 最低入库评分（0=全量入库，65=只入库值得关注以上）
SIGNAL_MIN_SCORE=0
# 批量评分分批大小
SIGNAL_BATCH_SIZE=50
# 前端默认展示数
SIGNAL_TOP_N=100
# 评分权重（5 项之和为 1.0）
SIGNAL_W_VOL_PRICE=0.30
SIGNAL_W_TREND=0.25
SIGNAL_W_MOMENTUM=0.20
SIGNAL_W_ANOMALY=0.15
SIGNAL_W_INTRADAY=0.10
